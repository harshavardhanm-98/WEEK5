#include <stdio.h>
int main() {
    int i;
    printf("Demonstrating Break and Continue:\n");
    for (i = 1; i <= 10; i++) {
        if (i == 3) {
            continue; // Skip the rest of the loop for 3
        }
        if (i == 7) {
            break;    // Exit the loop entirely at 7
        }
        printf("%d ", i);
    }
    return 0;
}

