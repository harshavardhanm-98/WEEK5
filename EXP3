#include <stdio.h>
int main() {
    int i;
    printf("Demonstrating Break and Continue:\n");
    for (i = 1; i <= 10; i++) {
        if (i == 3) {
            continue; 
        }
        if (i == 7) {
            break;    
        }
        printf("%d ", i);
    }
    printf("\nREG NO:25331A05I5");
    return 0;
}

